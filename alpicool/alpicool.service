[Unit]

Description = Alpicool/MANTUM BLE Fridge
After = network.target bluetooth.service
StartLimitInterval = 200
StartLimitBurst = 5

[Service]
EnvironmentFile=-/etc/default/alpicool2mqtt
Type = simple
ExecStart = /usr/local/bin/alpicool.py ${ALPICOOL_MQTT} ${ALPICOOL_TOPIC} ${ALPICOOL_MAC} ${ALPICOOL_LOG_LEVEL} ${ALPICOOL_OPTS}
Restart = always
RestartSec = 30

[Install]

WantedBy = multi-user.target
